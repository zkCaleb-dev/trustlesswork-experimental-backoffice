# ── Server-only (never NEXT_PUBLIC, never reaches the browser) ───────────────
# The deployed core the BFF proxies to.
CORE_API_URL=https://trustless-core-production.up.railway.app

# BACKOFFICE_ADMIN key for the admin panel. Set ONLY in Vercel (server env).
# Leave empty to disable the admin panel. NEVER commit a real value.
BACKOFFICE_ADMIN_API_KEY=

# Secret used to sign the httpOnly session cookie. >=32 bytes.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
SESSION_COOKIE_NAME=tw_session

# ── Public (browser-exposed) — non-secret values ONLY ───────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_APP_NAME=Trustless Work Backoffice
